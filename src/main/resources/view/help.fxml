<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.egen.fitogen.ui.controller.HelpController"
            fitToWidth="true"
            hbarPolicy="NEVER">
    <content>
        <VBox spacing="18" styleClass="content-pane">
            <padding>
                <Insets top="4" right="4" bottom="4" left="4"/>
            </padding>

            <VBox spacing="4">
                <Label text="Pomoc i centrum operacyjne" styleClass="page-title"/>
                <Label text="Szybki start, najważniejsze zasady pracy oraz aktualna gotowość środowiska Fito Gen do pracy operacyjnej." styleClass="page-subtitle" wrapText="true"/>
            </VBox>

            <HBox spacing="16">
                <VBox styleClass="content-card" spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="Start systemu" styleClass="section-title"/>
                    <Label fx:id="startupChecklistLabel" wrapText="true"/>
                </VBox>

                <VBox styleClass="content-card" spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="Codzienny workflow" styleClass="section-title"/>
                    <Label fx:id="dailyWorkflowLabel" wrapText="true"/>
                </VBox>
            </HBox>

            <HBox spacing="16">
                <VBox styleClass="content-card" spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="Dokumenty i partie" styleClass="section-title"/>
                    <Label fx:id="documentsTipsLabel" wrapText="true"/>
                </VBox>

                <VBox styleClass="content-card" spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="Rośliny i EPPO" styleClass="section-title"/>
                    <Label fx:id="plantsTipsLabel" wrapText="true"/>
                    <Label fx:id="eppoTipsLabel" wrapText="true"/>
                </VBox>
            </HBox>

            <HBox spacing="16">
                <VBox styleClass="content-card" spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="Ustawienia i administracja" styleClass="section-title"/>
                    <Label fx:id="settingsTipsLabel" wrapText="true"/>
                </VBox>

                <VBox styleClass="content-card" spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="Gotowość środowiska" styleClass="section-title"/>
                    <Label fx:id="systemReadinessLabel" wrapText="true"/>
                    <Label fx:id="nextActionLabel" wrapText="true"/>
                    <Label fx:id="supportScopeLabel" wrapText="true"/>
                    <Button text="Odśwież" onAction="#refreshHelp" styleClass="button-secondary"/>
                </VBox>
            </HBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Szybka nawigacja" styleClass="section-title"/>
                <HBox spacing="10">
                    <Button text="Pulpit" onAction="#openDashboard" styleClass="button-secondary"/>
                    <Button text="Ustawienia" onAction="#openSettings" styleClass="button-secondary"/>
                    <Button text="Rośliny" onAction="#openPlants" styleClass="button-secondary"/>
                    <Button text="Kontrahenci" onAction="#openContrahents" styleClass="button-secondary"/>
                </HBox>
                <HBox spacing="10">
                    <Button text="Partie roślin" onAction="#openPlantBatches" styleClass="button-secondary"/>
                    <Button text="Dokumenty" onAction="#openDocuments" styleClass="button-secondary"/>
                    <Button text="EPPO Admin" onAction="#openEppoAdmin" styleClass="button-secondary"/>
                    <Button text="Updates" onAction="#openUpdates" styleClass="button-secondary"/>
                </HBox>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
