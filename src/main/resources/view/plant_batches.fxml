<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.egen.fitogen.ui.controller.PlantBatchController"
      styleClass="content-pane">

    <Label text="Partie roślin" styleClass="section-title"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField"
                   promptText="Szukaj po roślinie, numerze partii, źródle pochodzenia, statusie i polach dodatkowych..."
                   HBox.hgrow="ALWAYS"/>
        <Button text="Wyczyść filtr" onAction="#clearFilters" styleClass="button-secondary"/>
    </HBox>

    <Label fx:id="filterStatusLabel" wrapText="true" styleClass="page-subtitle"/>
    <Label fx:id="filterSummaryLabel" wrapText="true" styleClass="page-subtitle"/>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn text="ID" fx:id="colId" prefWidth="60"/>
            <TableColumn text="Roślina" fx:id="colPlant" prefWidth="200"/>
            <TableColumn text="Nr partii wewnętrzny" fx:id="colInteriorBatchNo" prefWidth="170"/>
            <TableColumn text="Nr partii zewnętrzny" fx:id="colExteriorBatchNo" prefWidth="170"/>
            <TableColumn text="Ilość" fx:id="colQty" prefWidth="80"/>
            <TableColumn text="Data" fx:id="colCreationDate" prefWidth="110"/>
            <TableColumn text="Źródło pochodzenia" fx:id="colSourceOrigin" prefWidth="220"/>
            <TableColumn text="Status" fx:id="colStatus" prefWidth="110"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Dodaj" onAction="#addBatch"/>
        <Button text="Edytuj" onAction="#editBatch"/>
        <Button text="Anuluj" onAction="#deleteBatch" styleClass="button-danger"/>
    </HBox>

</VBox>