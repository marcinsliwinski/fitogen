<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.egen.fitogen.ui.controller.DocumentPreviewController"
            styleClass="content-pane">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="content-card">
            <Label text="Podgląd dokumentu" styleClass="page-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="cancelledBadge" text="ANULOWANY" styleClass="preview-cancelled-badge" visible="false"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" BorderPane.alignment="CENTER" styleClass="dashboard-scroll">
            <content>
                <VBox spacing="18" alignment="TOP_CENTER" style="-fx-padding: 20 20 20 20;">
                    <VBox fx:id="printableRoot" spacing="14" maxWidth="940" styleClass="preview-sheet preview-sheet-a4 preview-invoice-sheet">
                        <padding>
                            <Insets top="24" right="24" bottom="18" left="24"/>
                        </padding>

                        <HBox spacing="22" alignment="TOP_LEFT">
                            <VBox spacing="0" HBox.hgrow="ALWAYS" prefHeight="84" minHeight="84" maxHeight="84" styleClass="preview-logo-placeholder">
                                <Region VBox.vgrow="ALWAYS"/>
                            </VBox>
                            <VBox spacing="6" styleClass="preview-meta-panel" prefWidth="300">
                                <HBox spacing="0">
                                    <Label text="Miejsce wystawienia:" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" styleClass="preview-meta-strip-label"/>
                                    <Label fx:id="issuePlaceLabel" prefWidth="118" styleClass="preview-meta-strip-value"/>
                                </HBox>
                                <HBox spacing="0">
                                    <Label text="Data wystawienia:" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" styleClass="preview-meta-strip-label"/>
                                    <Label fx:id="issueDateLabel" prefWidth="118" styleClass="preview-meta-strip-value"/>
                                </HBox>
                            </VBox>
                        </HBox>

                        <HBox spacing="22">
                            <VBox spacing="0" HBox.hgrow="ALWAYS" styleClass="preview-party-box preview-party-box-flat">
                                <Label text="Wystawca:" styleClass="preview-box-header" maxWidth="1.7976931348623157E308"/>
                                <VBox spacing="3" styleClass="preview-box-body">
                                    <Label fx:id="issuerPartyNameLabel" styleClass="preview-subtitle"/>
                                    <Label fx:id="issuerPartyAddressLabel" wrapText="true" styleClass="preview-value"/>
                                    <Label fx:id="issuerPartyPhytosanitaryNumberLabel" wrapText="true" styleClass="preview-value"/>
                                </VBox>
                            </VBox>
                            <VBox spacing="0" HBox.hgrow="ALWAYS" styleClass="preview-party-box preview-party-box-flat">
                                <Label text="Nabywca:" styleClass="preview-box-header" maxWidth="1.7976931348623157E308"/>
                                <VBox spacing="3" styleClass="preview-box-body">
                                    <Label fx:id="customerNameLabel" styleClass="preview-subtitle"/>
                                    <Label fx:id="customerAddressLabel" wrapText="true" styleClass="preview-value"/>
                                    <Label fx:id="customerPhytosanitaryNumberLabel" wrapText="true" styleClass="preview-value"/>
                                </VBox>
                            </VBox>
                        </HBox>

                        <VBox spacing="2" alignment="CENTER">
                            <Label fx:id="documentTypeTitleLabel" styleClass="preview-invoice-title"/>
                            <Label fx:id="documentNumberTitleLabel" styleClass="preview-invoice-number"/>
                        </VBox>

                        <VBox spacing="1" alignment="CENTER_LEFT" styleClass="preview-authority-box">
                            <Label text="Państwowa Inspekcja Ochrony Roślin i Nasiennictwa" styleClass="preview-authority-line"/>
                            <Label text="PL / Jakość WE" styleClass="preview-authority-line"/>
                        </VBox>

                        <VBox spacing="0" styleClass="preview-items-wrap">
                            <TableView fx:id="itemsTable" styleClass="invoice-table preview-items-table">
                                <columns>
                                    <TableColumn fx:id="colLp" text="Lp" maxWidth="50" prefWidth="50"/>
                                    <TableColumn fx:id="colPlant" text="Nazwa rośliny (Gatunek, Podkładka, Odmiana)" prefWidth="420"/>
                                    <TableColumn fx:id="colBatch" text="Partia" prefWidth="150"/>
                                    <TableColumn fx:id="colAge" text="Wiek" prefWidth="60"/>
                                    <TableColumn fx:id="colCategory" text="Kategoria" prefWidth="115"/>
                                    <TableColumn fx:id="colQty" text="Ilość" prefWidth="70"/>
                                </columns>
                            </TableView>

                            <HBox fx:id="itemsSummaryRow" spacing="0" styleClass="preview-table-summary-row">
                                <Label fx:id="summaryLabelCell"
                                       text="Suma:"
                                       alignment="CENTER"
                                       styleClass="preview-table-summary-label"/>
                                <Label fx:id="totalQtyLabel"
                                       alignment="CENTER"
                                       styleClass="preview-table-summary-value"/>
                            </HBox>
                        </VBox>

                        <VBox fx:id="commentsSection" spacing="6" visible="false">
                            <Label text="Uwagi:" styleClass="preview-comments-title"/>
                            <Label fx:id="commentsLabel" wrapText="true" styleClass="preview-value"/>
                        </VBox>

                        <HBox spacing="26">
                            <VBox spacing="0" HBox.hgrow="ALWAYS" styleClass="preview-signature-box">
                                <Label text="Odebrał:" styleClass="preview-box-header" maxWidth="1.7976931348623157E308"/>
                                <VBox spacing="6" styleClass="preview-signature-body">
                                    <Region minHeight="58" VBox.vgrow="ALWAYS"/>
                                </VBox>
                            </VBox>
                            <VBox spacing="0" HBox.hgrow="ALWAYS" styleClass="preview-signature-box">
                                <Label text="Wystawił:" styleClass="preview-box-header" maxWidth="1.7976931348623157E308"/>
                                <VBox spacing="6" alignment="CENTER" styleClass="preview-signature-body">
                                    <Region minHeight="18" VBox.vgrow="ALWAYS"/>
                                    <Label fx:id="createdByLabel" styleClass="preview-subtitle"/>
                                    <Region minHeight="18" VBox.vgrow="ALWAYS"/>
                                </VBox>
                            </VBox>
                        </HBox>

                        <Label text="Fito Gen Essentials Powered by eGen Labs: www.egenlabs.eu"
                               styleClass="preview-document-footer"
                               maxWidth="1.7976931348623157E308"/>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER_RIGHT" styleClass="content-card">
            <Button text="Zamknij" onAction="#close" styleClass="button-secondary"/>
            <Button text="PDF" onAction="#exportPdf" styleClass="button-secondary"/>
            <Button text="Drukuj" onAction="#printDocument"/>
        </HBox>
    </bottom>
</BorderPane>
