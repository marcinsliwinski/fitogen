<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.egen.fitogen.ui.controller.DocumentPreviewController"
            styleClass="content-pane">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="content-card">
            <Label text="Podgląd dokumentu" styleClass="page-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="cancelledBadge" text="ANULOWANY" styleClass="preview-cancelled-badge" visible="false"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" BorderPane.alignment="CENTER" styleClass="dashboard-scroll">
            <content>
                <VBox spacing="18" alignment="TOP_CENTER" style="-fx-padding: 20 20 20 20;">
                    <VBox fx:id="printableRoot" spacing="14" maxWidth="840" styleClass="preview-sheet preview-sheet-a4 preview-invoice-sheet">
                        <padding>
                            <Insets top="24" right="24" bottom="24" left="24"/>
                        </padding>

                        <HBox spacing="22" alignment="TOP_LEFT">
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label fx:id="issuerNameLabel" styleClass="preview-invoice-issuer"/>
                                <Label fx:id="issuerAddressLabel" wrapText="true" styleClass="preview-value"/>
                                <Label fx:id="issuerPhytosanitaryNumberLabel" wrapText="true" styleClass="preview-value"/>
                            </VBox>
                            <VBox spacing="6" styleClass="preview-meta-panel" prefWidth="300">
                                <GridPane hgap="0" vgap="0">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="60"/>
                                        <ColumnConstraints percentWidth="40"/>
                                    </columnConstraints>

                                    <Label text="Miejsce wystawienia:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="preview-meta-strip-label"/>
                                    <Label fx:id="issuePlaceLabel" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="preview-meta-strip-value"/>
                                    <Label text="Data wystawienia:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="preview-meta-strip-label"/>
                                    <Label fx:id="issueDateLabel" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="preview-meta-strip-value"/>
                                    <Label text="Status:" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="preview-meta-strip-label"/>
                                    <Label fx:id="statusLabel" GridPane.rowIndex="2" GridPane.columnIndex="1" styleClass="preview-meta-strip-value"/>
                                    <Label text="Łączna ilość:" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="preview-meta-strip-label"/>
                                    <Label fx:id="totalQtyMetaLabel" GridPane.rowIndex="3" GridPane.columnIndex="1" styleClass="preview-meta-strip-value"/>
                                </GridPane>
                            </VBox>
                        </HBox>

                        <Label fx:id="previewSummaryLabel" wrapText="true" styleClass="page-subtitle"/>

                        <HBox spacing="22">
                            <VBox spacing="0" HBox.hgrow="ALWAYS" styleClass="preview-party-box preview-party-box-flat">
                                <Label text="Wystawca:" styleClass="preview-box-header" maxWidth="1.7976931348623157E308"/>
                                <VBox spacing="3" styleClass="preview-box-body">
                                    <Label fx:id="issuerPartyNameLabel" styleClass="preview-subtitle"/>
                                    <Label fx:id="issuerPartyAddressLabel" wrapText="true" styleClass="preview-value"/>
                                    <Label fx:id="issuerPartyPhytosanitaryNumberLabel" wrapText="true" styleClass="preview-value"/>
                                </VBox>
                            </VBox>
                            <VBox spacing="0" HBox.hgrow="ALWAYS" styleClass="preview-party-box preview-party-box-flat">
                                <Label text="Nabywca:" styleClass="preview-box-header" maxWidth="1.7976931348623157E308"/>
                                <VBox spacing="3" styleClass="preview-box-body">
                                    <Label fx:id="customerNameLabel" styleClass="preview-subtitle"/>
                                    <Label fx:id="customerAddressLabel" wrapText="true" styleClass="preview-value"/>
                                    <Label fx:id="customerPhytosanitaryNumberLabel" wrapText="true" styleClass="preview-value"/>
                                </VBox>
                            </VBox>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="16">
                            <Region HBox.hgrow="ALWAYS"/>
                            <VBox spacing="2" alignment="CENTER">
                                <Label fx:id="documentTypeTitleLabel" styleClass="preview-invoice-title"/>
                                <Label fx:id="documentNumberTitleLabel" styleClass="preview-invoice-number"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="copyMarkerLabel" styleClass="preview-copy-marker"/>
                        </HBox>

                        <TableView fx:id="itemsTable" styleClass="invoice-table">
                            <columns>
                                <TableColumn fx:id="colLp" text="Lp" maxWidth="55" prefWidth="55"/>
                                <TableColumn fx:id="colPlant" text="Nazwa" prefWidth="355"/>
                                <TableColumn fx:id="colBatch" text="Partia" prefWidth="220"/>
                                <TableColumn fx:id="colQty" text="Ilość" prefWidth="90"/>
                                <TableColumn fx:id="colPassport" text="Paszport" prefWidth="120"/>
                            </columns>
                        </TableView>

                        <HBox alignment="TOP_RIGHT">
                            <VBox spacing="0" prefWidth="320" styleClass="preview-totals-box">
                                <HBox spacing="0">
                                    <Label text="Liczba pozycji" HBox.hgrow="ALWAYS" styleClass="preview-total-label" maxWidth="1.7976931348623157E308"/>
                                    <Label fx:id="itemCountLabel" prefWidth="108" styleClass="preview-total-value"/>
                                </HBox>
                                <HBox spacing="0">
                                    <Label text="Razem do wydania" HBox.hgrow="ALWAYS" styleClass="preview-total-label preview-total-label-strong" maxWidth="1.7976931348623157E308"/>
                                    <Label fx:id="totalQtySummaryLabel" prefWidth="108" styleClass="preview-total-value preview-total-value-strong"/>
                                </HBox>
                            </VBox>
                        </HBox>

                        <VBox fx:id="commentsSection" spacing="6" visible="false">
                            <Label text="Uwagi:" styleClass="preview-comments-title"/>
                            <Label fx:id="commentsLabel" wrapText="true" styleClass="preview-value"/>
                        </VBox>

                        <HBox spacing="26">
                            <VBox spacing="0" HBox.hgrow="ALWAYS" styleClass="preview-signature-box">
                                <Label text="Odebrał:" styleClass="preview-box-header" maxWidth="1.7976931348623157E308"/>
                                <VBox spacing="6" styleClass="preview-signature-body">
                                    <Region minHeight="58" VBox.vgrow="ALWAYS"/>
                                    <Label text="Podpis osoby upoważnionej do odbioru dokumentu" wrapText="true" styleClass="form-info-label"/>
                                </VBox>
                            </VBox>
                            <VBox spacing="0" HBox.hgrow="ALWAYS" styleClass="preview-signature-box">
                                <Label text="Wystawił:" styleClass="preview-box-header" maxWidth="1.7976931348623157E308"/>
                                <VBox spacing="6" alignment="CENTER" styleClass="preview-signature-body">
                                    <Region minHeight="18" VBox.vgrow="ALWAYS"/>
                                    <Label fx:id="createdByLabel" styleClass="preview-subtitle"/>
                                    <Region minHeight="18" VBox.vgrow="ALWAYS"/>
                                    <Label text="Podpis osoby upoważnionej do wystawienia dokumentu" wrapText="true" styleClass="form-info-label"/>
                                </VBox>
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox spacing="8" maxWidth="980" styleClass="content-card">
                        <Label fx:id="warningSummaryLabel" text="Uwagi operacyjne do weryfikacji" styleClass="section-title"/>
                        <TextArea fx:id="warningArea"
                                  prefRowCount="5"
                                  wrapText="true"
                                  editable="false"
                                  focusTraversable="false"/>
                    </VBox>

                    <VBox spacing="8" maxWidth="980" styleClass="content-card">
                        <Label fx:id="eppoInfoSummaryLabel" text="Informacje EPPO i paszportowe" styleClass="section-title"/>
                        <TextArea fx:id="eppoInfoArea"
                                  prefRowCount="6"
                                  wrapText="true"
                                  editable="false"
                                  focusTraversable="false"/>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER_RIGHT" styleClass="content-card">
            <Button text="Zamknij" onAction="#close" styleClass="button-secondary"/>
            <Button text="PDF" onAction="#exportPdf" styleClass="button-secondary"/>
            <Button text="Drukuj" onAction="#printDocument"/>
        </HBox>
    </bottom>
</BorderPane>
