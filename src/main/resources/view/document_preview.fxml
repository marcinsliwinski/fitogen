<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.egen.fitogen.ui.controller.DocumentPreviewController"
            styleClass="content-pane">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="content-card">
            <Label text="Podgląd dokumentu" styleClass="page-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="cancelledBadge" text="ANULOWANY" styleClass="preview-cancelled-badge" visible="false"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" BorderPane.alignment="CENTER" styleClass="dashboard-scroll">
            <content>
                <VBox spacing="18" alignment="TOP_CENTER" style="-fx-padding: 20 20 20 20;">
                    <VBox fx:id="printableRoot" spacing="18" maxWidth="820" styleClass="preview-sheet preview-sheet-a4">
                        <padding>
                            <Insets top="28" right="30" bottom="28" left="30"/>
                        </padding>

                        <HBox spacing="18" alignment="TOP_LEFT">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Fito Gen Essentials" styleClass="preview-brand"/>
                                <Label text="Wizualizacja dokumentu do druku i PDF" styleClass="page-subtitle"/>
                                <Label fx:id="previewSummaryLabel" wrapText="true" styleClass="page-subtitle"/>
                            </VBox>
                            <VBox spacing="6" alignment="TOP_RIGHT">
                                <Label fx:id="documentTypeTitleLabel" styleClass="preview-document-type"/>
                                <Label fx:id="documentNumberTitleLabel" styleClass="preview-document-number" wrapText="true"/>
                            </VBox>
                        </HBox>

                        <Separator/>

                        <GridPane hgap="16" vgap="10">
                            <columnConstraints>
                                <ColumnConstraints minWidth="140" prefWidth="160"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                                <ColumnConstraints minWidth="140" prefWidth="160"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>

                            <Label text="Status" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="preview-meta-label"/>
                            <Label fx:id="statusLabel" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="preview-meta-value"/>
                            <Label text="Data wystawienia" GridPane.rowIndex="0" GridPane.columnIndex="2" styleClass="preview-meta-label"/>
                            <Label fx:id="issueDateLabel" GridPane.rowIndex="0" GridPane.columnIndex="3" styleClass="preview-meta-value"/>

                            <Label text="Utworzył" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="preview-meta-label"/>
                            <Label fx:id="createdByLabel" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="preview-meta-value"/>
                            <Label text="Łączna ilość" GridPane.rowIndex="1" GridPane.columnIndex="2" styleClass="preview-meta-label"/>
                            <Label fx:id="totalQtyLabel" GridPane.rowIndex="1" GridPane.columnIndex="3" styleClass="preview-meta-value"/>
                        </GridPane>

                        <HBox spacing="24">
                            <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="preview-party-box">
                                <Label text="Wystawca" styleClass="section-title"/>
                                <Label fx:id="issuerNameLabel" styleClass="preview-subtitle"/>
                                <Label fx:id="issuerAddressLabel" wrapText="true" styleClass="preview-value"/>
                                <Label fx:id="issuerPhytosanitaryNumberLabel" wrapText="true" styleClass="preview-value"/>
                            </VBox>
                            <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="preview-party-box">
                                <Label text="Odbiorca" styleClass="section-title"/>
                                <Label fx:id="customerNameLabel" styleClass="preview-subtitle"/>
                                <Label fx:id="customerAddressLabel" wrapText="true" styleClass="preview-value"/>
                                <Label fx:id="customerPhytosanitaryNumberLabel" wrapText="true" styleClass="preview-value"/>
                            </VBox>
                        </HBox>

                        <VBox spacing="8">
                            <Label text="Pozycje dokumentu" styleClass="section-title"/>
                            <TableView fx:id="itemsTable">
                                <columns>
                                    <TableColumn fx:id="colLp" text="Lp" maxWidth="50" prefWidth="50"/>
                                    <TableColumn fx:id="colPlant" text="Roślina" prefWidth="300"/>
                                    <TableColumn fx:id="colBatch" text="Partia" prefWidth="220"/>
                                    <TableColumn fx:id="colQty" text="Ilość" prefWidth="90"/>
                                    <TableColumn fx:id="colPassport" text="Paszport" prefWidth="120"/>
                                </columns>
                            </TableView>
                        </VBox>

                        <VBox fx:id="commentsSection" spacing="8" visible="false">
                            <Label text="Uwagi" styleClass="section-title"/>
                            <Label fx:id="commentsLabel" wrapText="true" styleClass="preview-value"/>
                        </VBox>

                        <Separator/>

                        <HBox spacing="26">
                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <Region minHeight="48" styleClass="signature-line"/>
                                <Label text="Podpis wystawcy" styleClass="form-info-label"/>
                            </VBox>
                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <Region minHeight="48" styleClass="signature-line"/>
                                <Label text="Podpis odbiorcy" styleClass="form-info-label"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox spacing="8" maxWidth="980" styleClass="content-card">
                        <Label fx:id="warningSummaryLabel" text="Uwagi operacyjne do weryfikacji" styleClass="section-title"/>
                        <TextArea fx:id="warningArea"
                                  prefRowCount="5"
                                  wrapText="true"
                                  editable="false"
                                  focusTraversable="false"/>
                    </VBox>

                    <VBox spacing="8" maxWidth="980" styleClass="content-card">
                        <Label fx:id="eppoInfoSummaryLabel" text="Informacje EPPO i paszportowe" styleClass="section-title"/>
                        <TextArea fx:id="eppoInfoArea"
                                  prefRowCount="6"
                                  wrapText="true"
                                  editable="false"
                                  focusTraversable="false"/>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER_RIGHT" styleClass="content-card">
            <Button text="Zamknij" onAction="#close" styleClass="button-secondary"/>
            <Button text="PDF" onAction="#exportPdf" styleClass="button-secondary"/>
            <Button text="Drukuj" onAction="#printDocument"/>
        </HBox>
    </bottom>
</BorderPane>
