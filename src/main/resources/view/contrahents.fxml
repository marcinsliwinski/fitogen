<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.egen.fitogen.ui.controller.ContrahentController"
      styleClass="content-pane">

    <Label text="Kontrahenci" styleClass="section-title"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField"
                   promptText="Szukaj po nazwie, kraju, mieście lub numerze fitosanitarnym..."
                   HBox.hgrow="ALWAYS"/>
            <Button text="Wyczyść filtr" onAction="#clearFilters" styleClass="button-secondary"/>
    </HBox>

    <Label fx:id="filterStatusLabel" wrapText="true" styleClass="page-subtitle"/>
    <Label fx:id="filterSummaryLabel" wrapText="true" styleClass="page-subtitle"/>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn text="ID" fx:id="colId" prefWidth="70"/>
            <TableColumn text="Nazwa" fx:id="colName" prefWidth="260"/>
            <TableColumn text="Kraj" fx:id="colCountry" prefWidth="160"/>
            <TableColumn text="Miasto" fx:id="colCity" prefWidth="160"/>
            <TableColumn text="Klient" fx:id="colClient" prefWidth="90"/>
            <TableColumn text="Dostawca" fx:id="colSupplier" prefWidth="100"/>
            <TableColumn text="Nr fitosanitarny" fx:id="colPhyto" prefWidth="190"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Dodaj" onAction="#addContrahent"/>
        <Button text="Edytuj" onAction="#editContrahent"/>
        <Button text="Usuń" onAction="#deleteContrahent" styleClass="button-danger"/>
    </HBox>

</VBox>