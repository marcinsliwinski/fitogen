<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.egen.fitogen.ui.controller.ImprovementController"
            fitToWidth="true"
            hbarPolicy="NEVER">
    <content>
        <VBox spacing="18" styleClass="content-pane">
            <padding>
                <Insets top="4" right="4" bottom="4" left="4"/>
            </padding>

            <VBox spacing="4">
                <Label text="Zgłoś ulepszenie" styleClass="page-title"/>
                <Label text="Formularz jest gotowy pod docelową wysyłkę przez API. Jeśli wysyłka API się nie powiedzie, system zaproponuje ręczne zgłoszenie na adres fallback ustawiony w Ustawieniach." styleClass="page-subtitle" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Szczegóły zgłoszenia" styleClass="section-title"/>
                <GridPane hgap="12" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints minWidth="200"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>

                    <Label text="Rodzaj ulepszenia" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="improvementTypeBox" promptText="Wybierz rodzaj" maxWidth="1.7976931348623157E308" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Krótki tytuł" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="improvementTitleField" promptText="Krótka nazwa ulepszenia" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Opis" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextArea fx:id="improvementDescriptionArea" wrapText="true" prefRowCount="6" promptText="Opisz problem, potrzebę lub propozycję ulepszenia" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Oczekiwany efekt / korzyść" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <TextArea fx:id="improvementExpectedBenefitArea" wrapText="true" prefRowCount="4" promptText="Jaki efekt biznesowy lub operacyjny powinno dać to ulepszenie?" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                    <Label text="Priorytet" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="improvementPriorityBox" promptText="Wybierz priorytet" maxWidth="1.7976931348623157E308" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                </GridPane>
            </VBox>

            <HBox spacing="16">
                <VBox styleClass="content-card" spacing="12" HBox.hgrow="ALWAYS">
                    <Label text="Załączniki" styleClass="section-title"/>
                    <Label text="Załączniki nie są jeszcze wysyłane automatycznie przez API. W trybie ręcznym system przygotuje szkic zgłoszenia i poda ścieżki plików do dołączenia ręcznie." wrapText="true" styleClass="page-subtitle"/>
                    <ListView fx:id="improvementAttachmentsList" prefHeight="220" VBox.vgrow="ALWAYS"/>
                    <HBox spacing="10">
                        <Button text="Dodaj załączniki" onAction="#addAttachments"/>
                        <Button text="Usuń zaznaczony" onAction="#removeSelectedAttachment" styleClass="button-secondary"/>
                    </HBox>
                </VBox>

                <VBox styleClass="content-card" spacing="12" HBox.hgrow="ALWAYS">
                    <Label text="Kanał wysyłki" styleClass="section-title"/>
                    <Label fx:id="improvementDeliveryModeLabel" wrapText="true"/>
                    <Label text="Kontekst techniczny dołączany automatycznie" styleClass="stat-title"/>
                    <Label fx:id="improvementTechnicalContextLabel" wrapText="true" styleClass="page-subtitle"/>
                    <Label text="Jeśli chcesz zmienić adres fallbacku, zrób to w Ustawieniach → Dane podmiotu." wrapText="true" styleClass="page-subtitle"/>
                    <HBox spacing="10">
                        <Button text="Ustawienia" onAction="#openSettings" styleClass="button-secondary"/>
                        <Button text="Pomoc" onAction="#openHelp" styleClass="button-secondary"/>
                    </HBox>
                </VBox>
            </HBox>

            <VBox styleClass="content-card" spacing="10">
                <Label text="Status" styleClass="section-title"/>
                <Label fx:id="improvementStatusLabel" wrapText="true" styleClass="page-subtitle"/>
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Wyczyść formularz" onAction="#clearForm" styleClass="button-secondary"/>
                    <Button text="Wyślij zgłoszenie" onAction="#submitImprovement"/>
                </HBox>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
