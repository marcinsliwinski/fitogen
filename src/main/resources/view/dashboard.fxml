<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.egen.fitogen.ui.controller.DashboardController"
            fitToWidth="true"
            hbarPolicy="NEVER">

    <content>
        <VBox spacing="18" styleClass="content-pane">
            <padding>
                <Insets top="4" right="4" bottom="4" left="4"/>
            </padding>

            <VBox spacing="4">
                <Label text="Pulpit" styleClass="page-title"/>
                <Label text="Stan systemu i najważniejsze dane operacyjne Fito Gen." styleClass="page-subtitle"/>
            </VBox>

            <FlowPane hgap="16" vgap="16" prefWrapLength="1100">
                <VBox styleClass="stat-card" prefWidth="240" spacing="8">
                    <Label text="Rośliny" styleClass="stat-title"/>
                    <Label fx:id="plantsCountLabel" text="0" styleClass="stat-value"/>
                </VBox>

                <VBox styleClass="stat-card" prefWidth="240" spacing="8">
                    <Label text="Kontrahenci" styleClass="stat-title"/>
                    <Label fx:id="contrahentsCountLabel" text="0" styleClass="stat-value"/>
                </VBox>

                <VBox styleClass="stat-card" prefWidth="240" spacing="8">
                    <Label text="Partie roślin" styleClass="stat-title"/>
                    <Label fx:id="batchesCountLabel" text="0" styleClass="stat-value"/>
                </VBox>

                <VBox styleClass="stat-card" prefWidth="240" spacing="8">
                    <Label text="Dokumenty" styleClass="stat-title"/>
                    <Label fx:id="documentsCountLabel" text="0" styleClass="stat-value"/>
                </VBox>
            </FlowPane>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Szybkie akcje" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <HBox spacing="10">
                    <Button text="Dodaj roślinę" onAction="#addPlant"/>
                    <Button text="Dodaj kontrahenta" onAction="#addContrahent"/>
                    <Button text="Dodaj partię" onAction="#addBatch"/>
                    <Button text="Dodaj dokument" onAction="#addDocument"/>
                </HBox>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Stan systemu" styleClass="section-title" style="-fx-font-size: 18px;"/>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Kopia zapasowa" styleClass="stat-title"/>
                        <Label fx:id="backupStatusValueLabel" wrapText="true"/>
                    </VBox>

                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Dane podmiotu" styleClass="stat-title"/>
                        <Label fx:id="issuerStatusValueLabel" wrapText="true"/>
                    </VBox>
                </HBox>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Status dokumentów" styleClass="stat-title"/>
                        <Label fx:id="documentsStatusValueLabel" wrapText="true"/>
                    </VBox>

                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Status partii" styleClass="stat-title"/>
                        <Label fx:id="batchesStatusValueLabel" wrapText="true"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox fx:id="issuerIncompleteBox" styleClass="content-card" spacing="12" visible="false">
                <Label text="Dane firmy / podmiotu wymagają uzupełnienia" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Label text="Profil szkółki / wystawcy jest niekompletny. Uzupełnij dane podmiotu w ustawieniach, aby pulpit i kolejne moduły mogły korzystać z pełnych danych." wrapText="true"/>
                <HBox spacing="10">
                    <Button fx:id="completeIssuerButton"
                            text="Uzupełnij w ustawieniach"
                            onAction="#openSettings"
                            styleClass="button-danger"/>
                </HBox>
            </VBox>

            <HBox spacing="16">
                <VBox styleClass="content-card" spacing="12" HBox.hgrow="ALWAYS">
                    <Label text="Ostatnie dokumenty" styleClass="section-title" style="-fx-font-size: 18px;"/>
                    <Label text="Kliknij pozycję, aby otworzyć podgląd dokumentu." styleClass="page-subtitle"/>
                    <VBox fx:id="recentDocumentsBox" spacing="8"/>
                </VBox>

                <VBox styleClass="content-card" spacing="12" HBox.hgrow="ALWAYS">
                    <Label text="Najnowsze partie roślin" styleClass="section-title" style="-fx-font-size: 18px;"/>
                    <Label text="Kliknij pozycję, aby otworzyć podgląd i edycję partii." styleClass="page-subtitle"/>
                    <VBox fx:id="recentBatchesBox" spacing="8"/>
                </VBox>
            </HBox>
        </VBox>
    </content>
</ScrollPane>