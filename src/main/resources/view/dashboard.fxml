<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.egen.fitogen.ui.controller.DashboardController"
            fitToWidth="true"
            hbarPolicy="NEVER">

    <content>
        <VBox spacing="18" styleClass="content-pane">
            <padding>
                <Insets top="4" right="4" bottom="4" left="4"/>
            </padding>

            <VBox spacing="4">
                <Label text="Pulpit" styleClass="page-title"/>
                <Label text="Najważniejsze informacje operacyjne i szybki dostęp do ostatnich działań." styleClass="page-subtitle"/>
            </VBox>

            <HBox spacing="12" fillHeight="false" styleClass="dashboard-cards-pane">
                <VBox fx:id="backupCardBox" styleClass="stat-card dashboard-stat-card dashboard-clickable-card dashboard-primary-card" maxWidth="1.7976931348623157E308" minWidth="180" spacing="8" prefHeight="132" HBox.hgrow="ALWAYS" onMouseClicked="#openBackupSettings">
                    <Label text="Kopia zapasowa" styleClass="stat-title"/>
                    <Label fx:id="backupStatusValueLabel" text="—" styleClass="stat-value" wrapText="true"/>
                    <Label fx:id="backupStatusNoteLabel" text="Stan kopii zapasowej bieżącej bazy." styleClass="stat-note" wrapText="true"/>
                </VBox>

                <VBox styleClass="stat-card dashboard-stat-card dashboard-secondary-card" maxWidth="1.7976931348623157E308" minWidth="180" spacing="8" prefHeight="132" HBox.hgrow="ALWAYS">
                    <Label text="Rośliny" styleClass="stat-title"/>
                    <Label fx:id="plantsCountLabel" text="0" styleClass="stat-value"/>
                    <Label fx:id="plantsCountNoteLabel" styleClass="stat-note" wrapText="true"/>
                </VBox>

                <VBox styleClass="stat-card dashboard-stat-card dashboard-secondary-card" maxWidth="1.7976931348623157E308" minWidth="180" spacing="8" prefHeight="132" HBox.hgrow="ALWAYS">
                    <Label text="Kontrahenci" styleClass="stat-title"/>
                    <Label fx:id="contrahentsCountLabel" text="0" styleClass="stat-value"/>
                    <Label fx:id="contrahentsCountNoteLabel" styleClass="stat-note" wrapText="true"/>
                </VBox>

                <VBox styleClass="stat-card dashboard-stat-card dashboard-secondary-card" maxWidth="1.7976931348623157E308" minWidth="180" spacing="8" prefHeight="132" HBox.hgrow="ALWAYS">
                    <Label text="Partie roślin" styleClass="stat-title"/>
                    <Label fx:id="batchesCountLabel" text="0" styleClass="stat-value"/>
                    <Label fx:id="batchesCountNoteLabel" styleClass="stat-note" wrapText="true"/>
                </VBox>

                <VBox styleClass="stat-card dashboard-stat-card dashboard-secondary-card" maxWidth="1.7976931348623157E308" minWidth="180" spacing="8" prefHeight="132" HBox.hgrow="ALWAYS">
                    <Label text="Dokumenty" styleClass="stat-title"/>
                    <Label fx:id="documentsCountLabel" text="0" styleClass="stat-value"/>
                    <Label fx:id="documentsCountNoteLabel" styleClass="stat-note" wrapText="true"/>
                </VBox>
            </HBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Szybkie akcje" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <HBox spacing="10">
                    <Button text="Dodaj roślinę" onAction="#addPlant"/>
                    <Button text="Dodaj kontrahenta" onAction="#addContrahent"/>
                    <Button text="Dodaj partię" onAction="#addBatch"/>
                    <Button text="Dodaj dokument" onAction="#addDocument"/>
                </HBox>
            </VBox>

            <HBox spacing="16">
                <VBox styleClass="content-card" spacing="12" HBox.hgrow="ALWAYS">
                    <Label text="Ostatnie dokumenty" styleClass="section-title" style="-fx-font-size: 18px;"/>
                    <Label text="Dwukrotnie kliknij wiersz, aby otworzyć podgląd dokumentu." styleClass="page-subtitle"/>
                    <TableView fx:id="recentDocumentsTable" prefHeight="270" minHeight="270" maxHeight="270">
                        <columns>
                            <TableColumn fx:id="colRecentDocumentNumber" text="Numer" prefWidth="160"/>
                            <TableColumn fx:id="colRecentDocumentType" text="Typ dokumentu" prefWidth="180"/>
                            <TableColumn fx:id="colRecentDocumentContrahent" text="Kontrahent" prefWidth="220"/>
                            <TableColumn fx:id="colRecentDocumentDate" text="Data" prefWidth="96"/>
                        </columns>
                    </TableView>
                </VBox>

                <VBox styleClass="content-card" spacing="12" HBox.hgrow="ALWAYS">
                    <Label text="Ostatnie partie" styleClass="section-title" style="-fx-font-size: 18px;"/>
                    <Label text="Dwukrotnie kliknij wiersz, aby otworzyć partię." styleClass="page-subtitle"/>
                    <TableView fx:id="recentBatchesTable" prefHeight="270" minHeight="270" maxHeight="270">
                        <columns>
                            <TableColumn fx:id="colRecentBatchPlant" text="Roślina" prefWidth="220"/>
                            <TableColumn fx:id="colRecentBatchNumber" text="Partia" prefWidth="160"/>
                            <TableColumn fx:id="colRecentBatchContrahent" text="Kontrahent / Dostawca" prefWidth="190"/>
                            <TableColumn fx:id="colRecentBatchQty" text="Ilość" prefWidth="90"/>
                        </columns>
                    </TableView>
                </VBox>
            </HBox>
        </VBox>
    </content>
</ScrollPane>
