<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.egen.fitogen.ui.controller.DocumentController"
      styleClass="content-pane">

    <Label text="Dokumenty" styleClass="section-title"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField"
                   promptText="Szukaj po numerze, typie, kontrahencie, statusie, dacie, utworzył i uwagach..."
                   HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="statusFilterBox" prefWidth="160"/>
        <Button text="Wyczyść filtry" onAction="#clearFilters" styleClass="button-secondary"/>
    </HBox>

    <Label fx:id="filterStatusLabel" wrapText="true" styleClass="page-subtitle"/>
    <Label fx:id="filterSummaryLabel" wrapText="true" styleClass="page-subtitle"/>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn text="ID" fx:id="colId" prefWidth="70"/>
            <TableColumn text="Numer" fx:id="colNumber" prefWidth="170"/>
            <TableColumn text="Typ" fx:id="colType" prefWidth="140"/>
            <TableColumn text="Klient" fx:id="colContrahent" prefWidth="190"/>
            <TableColumn text="Utworzył" fx:id="colCreatedBy" prefWidth="130"/>
            <TableColumn text="Data wystawienia" fx:id="colIssueDate" prefWidth="130"/>
            <TableColumn text="Status" fx:id="colStatus" prefWidth="110"/>
            <TableColumn text="Uwagi" fx:id="colComments" prefWidth="220"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Dodaj" onAction="#addDocument"/>
        <Button text="Edytuj" onAction="#editDocument"/>
        <Button text="Podgląd" onAction="#previewDocument" styleClass="button-secondary"/>
        <Button text="Drukuj" onAction="#printDocument" styleClass="button-secondary"/>
        <Button text="Anuluj" onAction="#deleteDocument" styleClass="button-danger"/>
    </HBox>

</VBox>