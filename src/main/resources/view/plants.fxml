<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.egen.fitogen.ui.controller.PlantsController"
      styleClass="content-pane">

    <Label text="Rośliny" styleClass="section-title"/>
    <Label fx:id="catalogModeInfoLabel" styleClass="page-subtitle" wrapText="true"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField"
                   promptText="Szukaj po gatunku, odmianie, podkładce, nazwie łacińskiej, kodzie EPPO, paszporcie lub statusie..."
                   HBox.hgrow="ALWAYS"/>
            <Button text="Wyczyść filtr" onAction="#clearFilters" styleClass="button-secondary"/>
    </HBox>

    <Label fx:id="filterStatusLabel" styleClass="page-subtitle" wrapText="true"/>
    <Label fx:id="filterSummaryLabel" styleClass="page-subtitle" wrapText="true"/>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn text="ID" fx:id="colId" prefWidth="70"/>
            <TableColumn text="Gatunek" fx:id="colSpecies" prefWidth="170"/>
            <TableColumn text="Odmiana" fx:id="colVariety" prefWidth="160"/>
            <TableColumn text="Podkładka" fx:id="colRootstock" prefWidth="160"/>
            <TableColumn text="Nazwa łacińska" fx:id="colLatin" prefWidth="210"/>
            <TableColumn text="Kod EPPO" fx:id="colEppo" prefWidth="120"/>
            <TableColumn text="Paszport" fx:id="colPassportRequired" prefWidth="110"/>
            <TableColumn text="Status indeksu" fx:id="colVisibility" prefWidth="130"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Dodaj" onAction="#addPlant"/>
        <Button text="Edytuj" onAction="#editPlant"/>
        <Button text="Usuń" onAction="#deletePlant" styleClass="button-danger"/>
    </HBox>

</VBox>