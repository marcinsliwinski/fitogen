<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.egen.fitogen.ui.controller.EppoCodeFormController"
      styleClass="form-root">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <VBox spacing="4">
        <Label text="Kod EPPO" styleClass="form-title"/>
        <Label text="W jednym miejscu przypisz kod EPPO do wielu gatunków referencyjnych i wielu krajów / stref EPPO. Na tej podstawie system będzie automatycznie dopasowywał rośliny." styleClass="form-subtitle" wrapText="true"/>
    </VBox>

    <VBox spacing="12">
        <Label text="Dane podstawowe" styleClass="form-section-title"/>

        <GridPane hgap="12" vgap="12">
            <columnConstraints>
                <ColumnConstraints minWidth="120" prefWidth="130"/>
                <ColumnConstraints hgrow="ALWAYS" minWidth="180"/>
                <ColumnConstraints minWidth="120" prefWidth="130"/>
                <ColumnConstraints hgrow="ALWAYS" minWidth="240"/>
                <ColumnConstraints minWidth="120" prefWidth="130"/>
                <ColumnConstraints hgrow="ALWAYS" minWidth="240"/>
            </columnConstraints>

            <Label text="Kod EPPO:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="codeField"
                       promptText="Wpisz kod EPPO"
                       GridPane.rowIndex="0"
                       GridPane.columnIndex="1"/>

            <Label text="Nazwa polska:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
            <TextField fx:id="polishNameField"
                       promptText="Wpisz nazwę polską"
                       GridPane.rowIndex="0"
                       GridPane.columnIndex="3"/>

            <Label text="Nazwa łacińska:" GridPane.rowIndex="0" GridPane.columnIndex="4"/>
            <TextField fx:id="latinNameField"
                       promptText="Wpisz nazwę łacińską"
                       GridPane.rowIndex="0"
                       GridPane.columnIndex="5"/>

            <Label text="Status:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <ComboBox fx:id="statusBox"
                      promptText="Wybierz status"
                      maxWidth="1.7976931348623157E308"
                      GridPane.rowIndex="1"
                      GridPane.columnIndex="1"/>
        </GridPane>
    </VBox>

    <Separator styleClass="form-separator"/>

    <VBox spacing="12">
        <Label text="Przypisane gatunki" styleClass="form-section-title"/>

        <GridPane hgap="12" vgap="12">
            <columnConstraints>
                <ColumnConstraints minWidth="170" prefWidth="190"/>
                <ColumnConstraints hgrow="ALWAYS" minWidth="520"/>
                <ColumnConstraints minWidth="220" prefWidth="250"/>
                <ColumnConstraints minWidth="220" prefWidth="250"/>
            </columnConstraints>

            <Label text="Gatunek / Nazwa łacińska:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <ComboBox fx:id="speciesDisplayField"
                      promptText="Wpisz lub wybierz gatunek / nazwę łacińską"
                      editable="true"
                      maxWidth="1.7976931348623157E308"
                      GridPane.rowIndex="0"
                      GridPane.columnIndex="1"/>
            <Button fx:id="speciesConnectButton"
                    text="Połącz gatunek z kodem EPPO"
                    onAction="#addSpeciesLink"
                    styleClass="button-primary"
                    GridPane.rowIndex="0"
                    GridPane.columnIndex="2"/>
            <Button fx:id="speciesDisconnectButton"
                    text="Odłącz gatunek od kodu EPPO"
                    onAction="#removeSelectedSpeciesLink"
                    styleClass="button-secondary"
                    GridPane.rowIndex="0"
                    GridPane.columnIndex="3"/>
        </GridPane>

        <Label fx:id="speciesSummaryLabel" text="Przypisane gatunki: 0" wrapText="true"/>

        <TableView fx:id="speciesTable" prefHeight="420">
            <columns>
                <TableColumn fx:id="colSpeciesDisplay" text="Gatunek / Nazwa łacińska" prefWidth="980"/>
            </columns>
        </TableView>
    </VBox>

    <Separator styleClass="form-separator"/>

    <VBox spacing="12">
        <Label text="Przypisane kraje / strefy EPPO" styleClass="form-section-title"/>

        <GridPane hgap="12" vgap="12">
            <columnConstraints>
                <ColumnConstraints minWidth="170" prefWidth="190"/>
                <ColumnConstraints hgrow="ALWAYS" minWidth="420"/>
                <ColumnConstraints minWidth="240" prefWidth="270"/>
                <ColumnConstraints minWidth="240" prefWidth="270"/>
            </columnConstraints>

            <Label text="Skrót / Kraj:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <ComboBox fx:id="zonePickerField"
                      promptText="Wpisz lub wybierz skrót / kraj"
                      editable="true"
                      maxWidth="1.7976931348623157E308"
                      GridPane.rowIndex="0"
                      GridPane.columnIndex="1"/>
            <Button fx:id="zoneConnectButton"
                    text="Połącz kraj / strefę z kodem EPPO"
                    onAction="#addZoneLink"
                    styleClass="button-primary"
                    GridPane.rowIndex="0"
                    GridPane.columnIndex="2"/>
            <Button fx:id="zoneDisconnectButton"
                    text="Odłącz kraj / strefę od kodu EPPO"
                    onAction="#removeSelectedZoneLink"
                    styleClass="button-secondary"
                    GridPane.rowIndex="0"
                    GridPane.columnIndex="3"/>
        </GridPane>

        <Label fx:id="zoneSummaryLabel" text="Przypisane kraje / strefy EPPO: 0" wrapText="true"/>
        <Label text="Podpowiedzi oznaczone jako [istniejący rekord EPPO] pochodzą z aktualnej bazy EPPO. Pozycje oznaczone jako [wspólny słownik] są pobierane ze wspólnego katalogu krajów i zostaną zapisane do EPPO dopiero po zapisaniu formularza." wrapText="true"/>

        <TableView fx:id="zoneTable" prefHeight="340">
            <columns>
                <TableColumn fx:id="colZoneCode" text="Kod" prefWidth="140"/>
                <TableColumn fx:id="colZoneDisplay" text="Skrót / Kraj / Źródło" prefWidth="520"/>
                <TableColumn fx:id="colZoneStatus" text="Status" prefWidth="120"/>
            </columns>
        </TableView>
    </VBox>

    <HBox spacing="10" alignment="CENTER_RIGHT" styleClass="form-actions">
        <Button text="Anuluj" minWidth="110" onAction="#cancel"/>
        <Button text="Zapisz" minWidth="110" onAction="#save"/>
    </HBox>

</VBox>