<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.egen.fitogen.ui.controller.UpdatesController"
            fitToWidth="true"
            hbarPolicy="NEVER">

    <content>
        <VBox spacing="18" styleClass="content-pane">
            <padding>
                <Insets top="4" right="4" bottom="4" left="4"/>
            </padding>

            <VBox spacing="4">
                <Label text="Aktualizacje" styleClass="page-title"/>
                <Label text="Widok gotowości operacyjnej pod przyszłą aktualizację danych i aplikacji." styleClass="page-subtitle" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <HBox spacing="10">
                    <Label text="Wersja aplikacji" styleClass="section-title" style="-fx-font-size: 18px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Odśwież" onAction="#refreshStatus" styleClass="button-secondary"/>
                </HBox>
                <HBox spacing="10">
                    <Label text="Aktualna wersja:" styleClass="stat-title"/>
                    <Label fx:id="appVersionLabel"/>
                </HBox>
                <Label fx:id="moduleReadinessLabel" wrapText="true"/>
                <Label fx:id="recommendedActionLabel" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Status aktualizacji systemu" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Label fx:id="systemUpdateStatusLabel" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Status aktualizacji bazy roślin" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Label fx:id="plantDatabaseStatusLabel" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Stan techniczny" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Label fx:id="databaseLocationLabel" wrapText="true"/>
                <Label fx:id="databaseHealthLabel" wrapText="true"/>
                <Label fx:id="lastBackupInfoLabel" wrapText="true"/>
                <Label fx:id="lastBackupPathLabel" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Gotowość konfiguracji" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Label fx:id="issuerProfileStatusLabel" wrapText="true"/>
                <Label fx:id="documentTypesStatusLabel" wrapText="true"/>
                <Label fx:id="usersStatusLabel" wrapText="true"/>
                <Label fx:id="countryDirectoryStatusLabel" wrapText="true"/>
                <Label fx:id="plantSettingsStatusLabel" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Dalsze kroki" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Label text="Ten moduł nie wykonuje jeszcze automatycznej aktualizacji, ale pokazuje, czy środowisko jest gotowe do jej bezpiecznego wdrożenia w kolejnych etapach." wrapText="true"/>
                <HBox spacing="10">
                    <Button text="Ustawienia" onAction="#openSettings" styleClass="button-secondary"/>
                    <Button text="Pomoc" onAction="#openHelp" styleClass="button-secondary"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
