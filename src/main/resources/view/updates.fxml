<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.egen.fitogen.ui.controller.UpdatesController"
            fitToWidth="true"
            hbarPolicy="NEVER">

    <content>
        <VBox spacing="18" styleClass="content-pane">
            <padding>
                <Insets top="4" right="4" bottom="4" left="4"/>
            </padding>

            <VBox spacing="4">
                <Label text="Aktualizacje" styleClass="page-title"/>
                <Label text="Widok gotowości operacyjnej pod przyszłą aktualizację aplikacji, synchronizację danych z serwera i bezpieczne importy lokalne." styleClass="page-subtitle" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <HBox spacing="10">
                    <Label text="Wersja aplikacji" styleClass="section-title" style="-fx-font-size: 18px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Odśwież" onAction="#refreshStatus" styleClass="button-secondary"/>
                </HBox>
                <HBox spacing="10">
                    <Label text="Aktualna wersja:" styleClass="stat-title"/>
                    <Label fx:id="appVersionLabel"/>
                </HBox>
                <Label fx:id="moduleReadinessLabel" wrapText="true"/>
                <Label fx:id="recommendedActionLabel" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Status aktualizacji systemu" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Label fx:id="systemUpdateStatusLabel" wrapText="true"/>
                <Label fx:id="plantDatabaseStatusLabel" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Stan techniczny" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Label fx:id="databaseLocationLabel" wrapText="true"/>
                <Label fx:id="databaseHealthLabel" wrapText="true"/>
                <Label fx:id="lastBackupInfoLabel" wrapText="true"/>
                <Label fx:id="lastBackupPathLabel" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Gotowość konfiguracji" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Label fx:id="issuerProfileStatusLabel" wrapText="true"/>
                <Label fx:id="documentTypesStatusLabel" wrapText="true"/>
                <Label fx:id="usersStatusLabel" wrapText="true"/>
                <Label fx:id="countryDirectoryStatusLabel" wrapText="true"/>
                <Label fx:id="plantSettingsStatusLabel" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Mapa zakresów aktualizacji i importów" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Label fx:id="plantsScopeLabel" wrapText="true"/>
                <Label fx:id="eppoScopeLabel" wrapText="true"/>
                <Label fx:id="countriesScopeLabel" wrapText="true"/>
                <Label fx:id="contrahentsScopeLabel" wrapText="true"/>
                <Label fx:id="documentsScopeLabel" wrapText="true"/>
                <Label fx:id="scopeStrategySummaryLabel" wrapText="true"/>
                <Label fx:id="nextDeliveryRecommendationLabel" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Przygotowanie pod importy" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Label fx:id="importReadinessLabel" wrapText="true"/>
                <Label fx:id="importDataScopeLabel" wrapText="true"/>
                <Label fx:id="importRecommendationLabel" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <HBox spacing="10">
                    <Label text="Preview importu CSV dla Plants" styleClass="section-title" style="-fx-font-size: 18px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Wybierz plik CSV" onAction="#previewPlantImportFile" styleClass="button-secondary"/>
                    <Button text="Wyczyść preview" onAction="#clearPlantImportPreview" styleClass="button-secondary"/>
                </HBox>
                <Label fx:id="plantImportPreviewStatusLabel" wrapText="true"/>
                <Label fx:id="plantImportPreviewFileLabel" wrapText="true"/>
                <Label fx:id="plantImportPreviewSummaryLabel" wrapText="true"/>
                <TableView fx:id="plantImportPreviewTable" prefHeight="320">
                    <columns>
                        <TableColumn fx:id="colRowNumber" text="Wiersz" prefWidth="70"/>
                        <TableColumn fx:id="colSpecies" text="Gatunek" prefWidth="180"/>
                        <TableColumn fx:id="colVariety" text="Odmiana" prefWidth="150"/>
                        <TableColumn fx:id="colRootstock" text="Podkładka" prefWidth="130"/>
                        <TableColumn fx:id="colEppoCode" text="Kod EPPO" prefWidth="100"/>
                        <TableColumn fx:id="colPassportRequired" text="Paszport" prefWidth="85"/>
                        <TableColumn fx:id="colVisibilityStatus" text="Widoczność" prefWidth="110"/>
                        <TableColumn fx:id="colImportStatus" text="Status preview" prefWidth="140"/>
                        <TableColumn fx:id="colImportMessage" text="Komentarz" prefWidth="340"/>
                    </columns>
                </TableView>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Dalsze kroki" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Label text="Ten moduł nie wykonuje jeszcze automatycznej aktualizacji ani zapisu importów, ale pokazuje docelowy podział zakresów i gotowość środowiska do kolejnych etapów." wrapText="true"/>
                <HBox spacing="10">
                    <Button text="Ustawienia" onAction="#openSettings" styleClass="button-secondary"/>
                    <Button text="Pomoc" onAction="#openHelp" styleClass="button-secondary"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>
        </VBox>
    </content>
</ScrollPane>