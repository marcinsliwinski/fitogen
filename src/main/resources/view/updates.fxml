<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.egen.fitogen.ui.controller.UpdatesController"
            fitToWidth="true"
            hbarPolicy="NEVER">

    <content>
        <VBox spacing="18" styleClass="content-pane">
            <padding>
                <Insets top="4" right="4" bottom="4" left="4"/>
            </padding>

            <VBox spacing="4">
                <Label text="Aktualizacje" styleClass="page-title"/>
                <Label text="Moduł gotowy pod przyszłą aktualizację aplikacji oraz synchronizację danych z serwera." styleClass="page-subtitle" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Wersja aplikacji" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <HBox spacing="10">
                    <Label text="Aktualna wersja:" styleClass="stat-title"/>
                    <Label fx:id="appVersionLabel"/>
                </HBox>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Aktualizacja aplikacji" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Label fx:id="appUpdateStatusLabel" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Server Update — Plants" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Label fx:id="plantsUpdateStatusLabel" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Server Update — EPPO" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Label fx:id="eppoUpdateStatusLabel" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Server Update — wspólny słownik krajów" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Label fx:id="countriesUpdateStatusLabel" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Stan techniczny" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Label fx:id="lastBackupInfoLabel" wrapText="true"/>
                <Label fx:id="readinessSummaryLabel" wrapText="true"/>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
