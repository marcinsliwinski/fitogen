<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.egen.fitogen.ui.controller.UpdatesController"
            fitToWidth="true"
            hbarPolicy="NEVER">

    <content>
        <VBox spacing="18" styleClass="content-pane">
            <padding>
                <Insets top="4" right="4" bottom="4" left="4"/>
            </padding>

            <VBox spacing="4">
                <Label text="Aktualizacje" styleClass="page-title"/>
                <Label text="Moduł gotowy pod przyszłą aktualizację aplikacji oraz synchronizację danych z serwera." styleClass="page-subtitle" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Wersja aplikacji" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <HBox spacing="10">
                    <Label text="Aktualna wersja:" styleClass="stat-title"/>
                    <Label fx:id="appVersionLabel"/>
                </HBox>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Aktualizacja aplikacji" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Label fx:id="appUpdateStatusLabel" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Server Update — Plants" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Label fx:id="plantsUpdateStatusLabel" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Server Update — EPPO" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Label fx:id="eppoUpdateStatusLabel" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Server Update — wspólny słownik krajów" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Label fx:id="countriesUpdateStatusLabel" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Stan techniczny" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Label fx:id="lastBackupInfoLabel" wrapText="true"/>
                <Label fx:id="readinessSummaryLabel" wrapText="true"/>
            </VBox>

            <VBox styleClass="content-card" spacing="12">
                <Label text="Preview / dry-run Server Update" styleClass="section-title" style="-fx-font-size: 18px;"/>
                <Label fx:id="dryRunStatusLabel" wrapText="true"/>
                <HBox spacing="10">
                    <Button text="Generuj pełny preview" onAction="#previewAllDryRun"/>
                    <Button text="Wyczyść wszystko" onAction="#clearAllDryRunPreviews" styleClass="button-secondary"/>
                </HBox>

                <VBox spacing="8">
                    <Label text="Plants" styleClass="stat-title"/>
                    <HBox spacing="10">
                        <Label text="Lokalny preview gotowości pod przyszły Server Update Plants." wrapText="true" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <HBox spacing="10">
                        <Label text="To nie pobiera danych z serwera i nie zapisuje zmian." wrapText="true" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <HBox spacing="10">
                        <Button text="Generuj preview Plants" onAction="#previewPlantsDryRun"/>
                        <Button text="Wyczyść preview" onAction="#clearPlantsDryRunPreview" styleClass="button-secondary"/>
                    </HBox>
                    <TextArea fx:id="plantsDryRunPreviewArea" editable="false" wrapText="true" prefRowCount="8"/>
                </VBox>

                <VBox spacing="8">
                    <Label text="EPPO" styleClass="stat-title"/>
                    <HBox spacing="10">
                        <Label text="Lokalny preview gotowości pod przyszły Server Update EPPO." wrapText="true" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <HBox spacing="10">
                        <Label text="To nie pobiera danych z serwera i nie zapisuje zmian." wrapText="true" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <HBox spacing="10">
                        <Button text="Generuj preview EPPO" onAction="#previewEppoDryRun"/>
                        <Button text="Wyczyść preview" onAction="#clearEppoDryRunPreview" styleClass="button-secondary"/>
                    </HBox>
                    <TextArea fx:id="eppoDryRunPreviewArea" editable="false" wrapText="true" prefRowCount="8"/>
                </VBox>

                <VBox spacing="8">
                    <Label text="Wspólny słownik krajów" styleClass="stat-title"/>
                    <HBox spacing="10">
                        <Label text="Lokalny preview gotowości pod przyszły Server Update wspólnego słownika krajów." wrapText="true" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <HBox spacing="10">
                        <Label text="To nie pobiera danych z serwera i nie zapisuje zmian." wrapText="true" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <HBox spacing="10">
                        <Button text="Generuj preview słownika krajów" onAction="#previewCountriesDryRun"/>
                        <Button text="Wyczyść preview" onAction="#clearCountriesDryRunPreview" styleClass="button-secondary"/>
                    </HBox>
                    <TextArea fx:id="countriesDryRunPreviewArea" editable="false" wrapText="true" prefRowCount="8"/>
                </VBox>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
