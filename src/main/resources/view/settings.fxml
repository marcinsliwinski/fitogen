<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.egen.fitogen.ui.controller.SettingsController"
      styleClass="content-pane">

    <VBox spacing="4">
        <Label text="Ustawienia" styleClass="page-title"/>
        <Label text="Konfiguracja numeratora, słowników i ustawień technicznych systemu." styleClass="page-subtitle"/>
    </VBox>

    <TabPane fx:id="settingsTabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <tabs>
            <Tab text="Rośliny">
                <ScrollPane fitToWidth="true" fitToHeight="true">
                    <content>
                        <VBox spacing="16" styleClass="content-card">
                            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                            <VBox spacing="12" styleClass="stat-card">
                                <Label text="Paszporty roślin" styleClass="stat-title"/>
                                <Label text="To ustawienie steruje domyślnym wymogiem paszportu w formularzu rośliny. Gdy jest aktywne, pole w formularzu rośliny pozostaje zaznaczone i nieedytowalne." wrapText="true" styleClass="page-subtitle"/>
                                <CheckBox fx:id="plantPassportRequiredForAllCheckBox"
                                          text="Wymagaj paszportów roślin dla wszystkich roślin"/>
                                <Label fx:id="plantPassportModeStatusLabel" wrapText="true" styleClass="page-subtitle"/>
                                <HBox spacing="10" alignment="CENTER_RIGHT">
                                    <Button text="Zapisz ustawienie paszportów" onAction="#savePlantPassportMode"/>
                                </HBox>
                            </VBox>

                            <Separator/>

                            <VBox spacing="12" styleClass="stat-card">
                                <Label text="Tryb bazy roślin" styleClass="stat-title"/>
                                <Label text="Na tym etapie przełącznik steruje widocznością pozycji nieużywanych na liście Roślin. Nie usuwa żadnych danych." wrapText="true" styleClass="page-subtitle"/>
                                <CheckBox fx:id="plantFullCatalogEnabledCheckBox"
                                          text="Włącz pełną bazę roślin"/>
                                <Label fx:id="plantCatalogModeStatusLabel" wrapText="true" styleClass="page-subtitle"/>
                                <HBox spacing="10" alignment="CENTER_RIGHT">
                                    <Button text="Zapisz tryb bazy roślin" onAction="#savePlantCatalogMode"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </Tab>

            <Tab text="Numeracja">
                <ScrollPane fitToWidth="true" fitToHeight="true">
                    <content>
                        <VBox spacing="16" styleClass="content-card">
                            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                            <VBox spacing="8">
                                <Label text="Ustawienia numeracji" styleClass="stat-title"/>
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <Label text="Typ numeracji:" minWidth="140"/>
                                    <ComboBox fx:id="numberingTypeBox" prefWidth="240"/>
                                    <Label text="Bieżący licznik:" minWidth="120"/>
                                    <TextField fx:id="currentCounterField" prefWidth="120"/>
                                </HBox>
                            </VBox>

                            <Separator/>

                            <GridPane hgap="12" vgap="12">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="100"/>
                                    <ColumnConstraints minWidth="220" hgrow="ALWAYS"/>
                                    <ColumnConstraints minWidth="220" hgrow="ALWAYS"/>
                                    <ColumnConstraints minWidth="220" hgrow="ALWAYS"/>
                                </columnConstraints>

                                <Label text="" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                <Label text="Typ sekcji" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                <Label text="Wartość statyczna" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                                <Label text="Separator po sekcji" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                                <Label text="Sekcja 1" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="section1TypeBox" GridPane.rowIndex="1" GridPane.columnIndex="1" maxWidth="1.7976931348623157E308"/>
                                <TextField fx:id="section1StaticValueField" promptText="np. FG" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                                <TextField fx:id="section1SeparatorField" promptText="np. /" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                                <Label text="Sekcja 2" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="section2TypeBox" GridPane.rowIndex="2" GridPane.columnIndex="1" maxWidth="1.7976931348623157E308"/>
                                <TextField fx:id="section2StaticValueField" promptText="np. FG" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                                <TextField fx:id="section2SeparatorField" promptText="np. -" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                                <Label text="Sekcja 3" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="section3TypeBox" GridPane.rowIndex="3" GridPane.columnIndex="1" maxWidth="1.7976931348623157E308"/>
                                <TextField fx:id="section3StaticValueField" promptText="np. FG" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
                                <TextField fx:id="section3SeparatorField" promptText="np. brak" GridPane.rowIndex="3" GridPane.columnIndex="3"/>
                            </GridPane>

                            <VBox spacing="8" styleClass="stat-card">
                                <Label text="Podgląd kolejnego numeru" styleClass="stat-title"/>
                                <Label fx:id="previewLabel" text="—" styleClass="page-title"/>
                                <Label fx:id="infoLabel" text="Podgląd pokazuje kolejny numer dla bieżącej konfiguracji." styleClass="page-subtitle" wrapText="true"/>
                            </VBox>

                            <HBox spacing="10" alignment="CENTER_RIGHT">
                                <Button text="Przywróć domyślne" onAction="#restoreDefaults" styleClass="button-secondary"/>
                                <Button text="Zapisz konfigurację" onAction="#save"/>
                            </HBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </Tab>

            <Tab text="Typy dokumentów">
                <ScrollPane fitToWidth="true" fitToHeight="true">
                    <content>
                        <VBox spacing="16" styleClass="content-card">
                            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                            <VBox spacing="12" styleClass="stat-card">
                                <Label text="Typy dokumentów" styleClass="stat-title"/>
                                <Label text="Słownik typów dokumentów używanych w formularzach i na listach dokumentów. Na tym etapie pozostaje bez zmian w logice zapisu." wrapText="true" styleClass="page-subtitle"/>
                                <TextField fx:id="documentTypeSearchField" promptText="Szukaj typu dokumentu po nazwie lub kodzie"/>
                                <Label fx:id="documentTypeStatusLabel" wrapText="true" styleClass="page-subtitle"/>
                                <Label fx:id="documentTypeSummaryLabel" wrapText="true" styleClass="page-subtitle"/>
                                <HBox spacing="14">
                                    <ListView fx:id="documentTypesList" prefWidth="320" prefHeight="220"/>
                                    <VBox spacing="10" HBox.hgrow="ALWAYS">
                                        <TextField fx:id="documentTypeNameField" promptText="Nazwa typu dokumentu"/>
                                        <TextField fx:id="documentTypeCodeField" promptText="Kod, np. DD"/>
                                        <HBox spacing="10">
                                            <Button text="Wyczyść filtr" onAction="#clearDocumentTypeFilter" styleClass="button-secondary"/>
                                            <Region HBox.hgrow="ALWAYS"/>
                                            <Button text="Nowy" onAction="#clearDocumentTypeForm" styleClass="button-secondary"/>
                                            <Button text="Zapisz typ" onAction="#saveDocumentType"/>
                                            <Button text="Usuń typ" onAction="#deleteDocumentType" styleClass="button-danger"/>
                                        </HBox>
                                    </VBox>
                                </HBox>
                            </VBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </Tab>

            <Tab text="Słowniki">
                <ScrollPane fitToWidth="true" fitToHeight="true">
                    <content>
                        <VBox spacing="16" styleClass="content-card">
                            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                            <VBox spacing="12" styleClass="stat-card">
                                <Label text="Wspólny słownik krajów" styleClass="stat-title"/>
                                <Label text="Ten słownik jest współdzielony przez Kontrahentów, EPPO i dane podmiotu. Możesz dopisywać własne wpisy bez zmiany schematu bazy." wrapText="true" styleClass="page-subtitle"/>
                                <TextField fx:id="customCountrySearchField" promptText="Filtruj wspólny słownik krajów po nazwie kraju lub kodzie"/>
                                <Label fx:id="countryDictionaryStatusLabel" wrapText="true" styleClass="page-subtitle"/>
                                <Label fx:id="countryDictionarySummaryLabel" wrapText="true" styleClass="page-subtitle"/>

                                <Label text="Wspólny katalog krajów (jedna lista + kontrolki)" styleClass="page-subtitle"/>
                                <Label text="Jedna lista pokazuje pełny katalog bazowy i wpisy własne. Rekordy własne są oznaczone w liście, a kontrolki poniżej działają tylko dla wpisów własnych użytkownika." wrapText="true" styleClass="page-subtitle"/>
                                <ListView fx:id="allCountryEntriesList" prefHeight="260"/>

                                <VBox spacing="10">
                                    <TextField fx:id="customCountryNameField" promptText="Nazwa kraju dla wpisu własnego"/>
                                    <TextField fx:id="customCountryCodeField" promptText="Kod kraju, np. PL"/>
                                    <Label fx:id="customCountryUsageLabel" wrapText="true" styleClass="page-subtitle" text="Status użycia wybranego wpisu: brak zaznaczenia. Wybierz własny wpis, aby sprawdzić użycie w danych wystawcy i kontrahentach."/>
                                    <Label fx:id="customCountryUsageCountsLabel" wrapText="true" styleClass="page-subtitle" text="Licznik powiązań: brak zaznaczenia. Po wyborze własnego wpisu zobaczysz, czy używają go dane wystawcy oraz ilu kontrahentów."/>
                                    <HBox spacing="10">
                                        <Button text="Nowy wpis własny" onAction="#clearCustomCountryEntryForm" styleClass="button-secondary"/>
                                        <Button text="Wyczyść filtr" onAction="#clearCustomCountryFilter" styleClass="button-secondary"/>
                                        <Button text="Zapisz wpis własny" onAction="#saveCustomCountryEntry"/>
                                        <Button text="Usuń wpis własny" onAction="#deleteCustomCountryEntry" styleClass="button-danger"/>
                                    </HBox>
                                </VBox>
                            </VBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </Tab>

            <Tab text="Użytkownicy">
                <ScrollPane fitToWidth="true" fitToHeight="true">
                    <content>
                        <VBox spacing="16" styleClass="content-card">
                            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                            <Label text="Użytkownicy" styleClass="stat-title"/>
                            <HBox spacing="14">
                                <ListView fx:id="usersList" prefWidth="320" prefHeight="220"/>
                                <VBox spacing="10" HBox.hgrow="ALWAYS">
                                    <TextField fx:id="userFirstNameField" promptText="Imię"/>
                                    <TextField fx:id="userLastNameField" promptText="Nazwisko"/>
                                    <HBox spacing="10">
                                        <Button text="Nowy" onAction="#clearUserForm" styleClass="button-secondary"/>
                                        <Button text="Zapisz użytkownika" onAction="#saveUser"/>
                                        <Button text="Usuń użytkownika" onAction="#deleteUser" styleClass="button-danger"/>
                                    </HBox>
                                </VBox>
                            </HBox>

                            <Separator/>

                            <VBox spacing="10" styleClass="stat-card">
                                <Label text="Domyślny użytkownik dokumentów" styleClass="stat-title"/>
                                <Label text="Wybrany użytkownik będzie automatycznie podstawiany w nowych dokumentach. Pole może pozostać puste." wrapText="true" styleClass="page-subtitle"/>
                                <ComboBox fx:id="defaultUserBox" promptText="Brak domyślnego użytkownika" maxWidth="420"/>
                                <HBox spacing="10">
                                    <Button text="Wyczyść" onAction="#clearDefaultUser" styleClass="button-secondary"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </Tab>


            <Tab text="Import / Eksport CSV">
                <ScrollPane fitToWidth="true" fitToHeight="true">
                    <content>
                        <VBox spacing="16" styleClass="content-card">
                            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                            <VBox spacing="12" styleClass="stat-card">
                                <Label text="CSV roślin" styleClass="stat-title"/>
                                <Label text="Lokalny podgląd importu i eksport CSV dla roślin. Ten obszar pozostaje w Ustawieniach i nie jest częścią modułu Aktualizacje." wrapText="true" styleClass="page-subtitle"/>
                                <Label fx:id="plantsCsvColumnsLabel" wrapText="true" styleClass="page-subtitle"/>
                                <Label fx:id="plantsCsvStatusLabel" wrapText="true" styleClass="page-subtitle"/>
                                <HBox spacing="10">
                                    <Button text="Podgląd importu CSV roślin" onAction="#previewPlantsCsvImport"/>
                                    <Button fx:id="plantsCsvApplyButton" text="Importuj do bazy" onAction="#applyPlantsCsvImport" disable="true"/>
                                    <Button text="Eksport CSV roślin" onAction="#exportPlantsCsv" styleClass="button-secondary"/>
                                    <Button text="Wyczyść podgląd" onAction="#clearPlantsCsvPreview" styleClass="button-secondary"/>
                                </HBox>
                                <TextArea fx:id="plantsCsvPreviewArea" editable="false" wrapText="true" prefRowCount="10"/>
                            </VBox>

                            <Separator/>

                            <VBox spacing="12" styleClass="stat-card">
                                <Label text="CSV kontrahentów" styleClass="stat-title"/>
                                <Label text="Lokalny podgląd importu i eksport CSV dla kontrahentów w tym samym standardzie ustawień lokalnych." wrapText="true" styleClass="page-subtitle"/>
                                <Label fx:id="contrahentsCsvColumnsLabel" wrapText="true" styleClass="page-subtitle"/>
                                <Label fx:id="contrahentsCsvStatusLabel" wrapText="true" styleClass="page-subtitle"/>
                                <HBox spacing="10">
                                    <Button text="Podgląd importu CSV kontrahentów" onAction="#previewContrahentsCsvImport"/>
                                    <Button fx:id="contrahentsCsvApplyButton" text="Importuj do bazy" onAction="#applyContrahentsCsvImport" disable="true"/>
                                    <Button text="Eksport CSV kontrahentów" onAction="#exportContrahentsCsv" styleClass="button-secondary"/>
                                    <Button text="Wyczyść podgląd" onAction="#clearContrahentsCsvPreview" styleClass="button-secondary"/>
                                </HBox>
                                <TextArea fx:id="contrahentsCsvPreviewArea" editable="false" wrapText="true" prefRowCount="10"/>
                            </VBox>

                            <Separator/>

                            <VBox spacing="12" styleClass="stat-card">
                                <Label text="Dokumenty CSV" styleClass="stat-title"/>
                                <Label text="Lokalny podgląd importu i eksport CSV dla dokumentów. Format pozostaje w Ustawieniach -> Import / Eksport CSV i nie wchodzi do modułu Aktualizacje." wrapText="true" styleClass="page-subtitle"/>
                                <Label fx:id="documentsCsvColumnsLabel" wrapText="true" styleClass="page-subtitle"/>
                                <Label fx:id="documentsCsvStatusLabel" wrapText="true" styleClass="page-subtitle"/>
                                <HBox spacing="10">
                                    <Button text="Podgląd importu CSV dokumentów" onAction="#previewDocumentsCsvImport"/>
                                    <Button fx:id="documentsCsvApplyButton" text="Importuj do bazy" onAction="#applyDocumentsCsvImport" disable="true"/>
                                    <Button text="Eksport CSV dokumentów" onAction="#exportDocumentsCsv" styleClass="button-secondary"/>
                                    <Button text="Wyczyść podgląd" onAction="#clearDocumentsCsvPreview" styleClass="button-secondary"/>
                                </HBox>
                                <TextArea fx:id="documentsCsvPreviewArea" editable="false" wrapText="true" prefRowCount="12"/>
                            </VBox>

                            <Separator/>

                            <VBox spacing="12" styleClass="stat-card">
                                <Label text="EPPO CSV — eksport słowników" styleClass="stat-title"/>
                                <Label text="Pierwszy bezpieczny krok dla słowników EPPO: eksport aktualnego stanu do lokalnych plików CSV bez zmiany bazy. Import z podglądem i apply będzie kolejnym etapem." wrapText="true" styleClass="page-subtitle"/>

                                <Label text="Kody EPPO" styleClass="stat-title"/>
                                <Label fx:id="eppoCodesCsvColumnsLabel" wrapText="true" styleClass="page-subtitle"/>
                                <Label fx:id="eppoCodesCsvStatusLabel" wrapText="true" styleClass="page-subtitle"/>
                                <HBox spacing="10">
                                    <Button text="Eksport CSV kodów EPPO" onAction="#exportEppoCodesCsv" styleClass="button-secondary"/>
                                </HBox>

                                <Label text="Strefy EPPO" styleClass="stat-title"/>
                                <Label fx:id="eppoZonesCsvColumnsLabel" wrapText="true" styleClass="page-subtitle"/>
                                <Label fx:id="eppoZonesCsvStatusLabel" wrapText="true" styleClass="page-subtitle"/>
                                <HBox spacing="10">
                                    <Button text="Eksport CSV stref EPPO" onAction="#exportEppoZonesCsv" styleClass="button-secondary"/>
                                </HBox>

                                <Label text="Powiązania kod EPPO → gatunek" styleClass="stat-title"/>
                                <Label fx:id="eppoCodeSpeciesLinksCsvColumnsLabel" wrapText="true" styleClass="page-subtitle"/>
                                <Label fx:id="eppoCodeSpeciesLinksCsvStatusLabel" wrapText="true" styleClass="page-subtitle"/>
                                <HBox spacing="10">
                                    <Button text="Eksport CSV powiązań kod → gatunek" onAction="#exportEppoCodeSpeciesLinksCsv" styleClass="button-secondary"/>
                                </HBox>

                                <Label text="Powiązania kod EPPO → roślina" styleClass="stat-title"/>
                                <Label fx:id="eppoCodePlantLinksCsvColumnsLabel" wrapText="true" styleClass="page-subtitle"/>
                                <Label fx:id="eppoCodePlantLinksCsvStatusLabel" wrapText="true" styleClass="page-subtitle"/>
                                <HBox spacing="10">
                                    <Button text="Eksport CSV powiązań kod → roślina" onAction="#exportEppoCodePlantLinksCsv" styleClass="button-secondary"/>
                                </HBox>

                                <Label text="Powiązania kod EPPO → strefa" styleClass="stat-title"/>
                                <Label fx:id="eppoCodeZoneLinksCsvColumnsLabel" wrapText="true" styleClass="page-subtitle"/>
                                <Label fx:id="eppoCodeZoneLinksCsvStatusLabel" wrapText="true" styleClass="page-subtitle"/>
                                <HBox spacing="10">
                                    <Button text="Eksport CSV powiązań kod → strefa" onAction="#exportEppoCodeZoneLinksCsv" styleClass="button-secondary"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </Tab>


            <Tab text="Dziennik audytu">
                <ScrollPane fitToWidth="true" fitToHeight="true">
                    <content>
                        <VBox spacing="16" styleClass="content-card">
                            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                            <VBox spacing="12" styleClass="stat-card">
                                <Label text="Dziennik audytu" styleClass="stat-title"/>
                                <Label text="Podgląd ostatnich wpisów audytowych zapisanych w bazie. Na tym etapie ekran jest tylko do odczytu i nie zmienia sposobu logowania zdarzeń." wrapText="true" styleClass="page-subtitle"/>
                                <Label fx:id="auditLogStatusLabel" wrapText="true" styleClass="page-subtitle"/>
                                <Label text="Najnowszy wpis" styleClass="stat-title"/>
                                <Label fx:id="auditLogSummaryLabel" wrapText="true" styleClass="page-subtitle"/>
                                <TextField fx:id="auditLogSearchField" promptText="Filtruj wpisy dziennika audytu po użytkowniku, encji, akcji lub opisie..."/>
                                <HBox spacing="10">
                                    <Button text="Odśwież dziennik audytu" onAction="#refreshAuditLog" styleClass="button-secondary"/>
                                    <Button text="Wyczyść filtr" onAction="#clearAuditLogFilter" styleClass="button-secondary"/>
                                </HBox>
                                <TableView fx:id="auditLogTable" prefHeight="420">
                                    <columns>
                                        <TableColumn text="Data zmiany" fx:id="colAuditChangedAt" prefWidth="170"/>
                                        <TableColumn text="Użytkownik" fx:id="colAuditActor" prefWidth="130"/>
                                        <TableColumn text="Encja" fx:id="colAuditEntityType" prefWidth="120"/>
                                        <TableColumn text="ID" fx:id="colAuditEntityId" prefWidth="70"/>
                                        <TableColumn text="Akcja" fx:id="colAuditActionType" prefWidth="110"/>
                                        <TableColumn text="Opis" fx:id="colAuditDescription" prefWidth="420"/>
                                    </columns>
                                </TableView>
                            </VBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </Tab>

            <Tab text="Kopia zapasowa i baza">
                <ScrollPane fitToWidth="true" fitToHeight="true">
                    <content>
                        <VBox spacing="16" styleClass="content-card">
                            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                            <Label text="Aktywna baza danych" styleClass="stat-title"/>
                            <Label text="Wybierz bazę danych z katalogu użytkownika. Ostatnia pozycja listy pozwala od razu utworzyć nową bazę profilu." wrapText="true" styleClass="page-subtitle"/>
                            <Label text="Katalog baz danych:"/>
                            <Label fx:id="databaseFolderLabel" wrapText="true" styleClass="page-subtitle"/>
                            <ComboBox fx:id="databaseProfileBox" promptText="Wybierz bazę danych" maxWidth="420"/>
                            <TextField fx:id="newDatabaseNameField" promptText="Nazwa nowej bazy danych" managed="false" visible="false" maxWidth="420"/>
                            <Label text="Plik bazy danych:"/>
                            <Label fx:id="databasePathLabel" wrapText="true" styleClass="page-subtitle"/>
                            <Label text="Stan profilu:"/>
                            <Label fx:id="databaseProfileStatusLabel" wrapText="true" styleClass="page-subtitle"/>
                            <Label text="Walidacja ostatnio używanej bazy:"/>
                            <Label fx:id="databaseMissingStatusLabel" wrapText="true" styleClass="page-subtitle"/>
                            <HBox spacing="10">
                                <Button text="Użyj wybranej bazy" onAction="#applySelectedDatabaseProfile"/>
                                <Button text="Odzyskaj z backupu" onAction="#restoreDatabaseFromBackup" styleClass="button-secondary"/>
                                <Button text="Odśwież listę baz" onAction="#refreshDatabaseProfiles" styleClass="button-secondary"/>
                            </HBox>

                            <Separator/>

                            <Label text="Ręczna kopia zapasowa" styleClass="stat-title"/>
                            <Label text="Stan kopii zapasowej:"/>
                            <Label fx:id="backupStatusLabel" wrapText="true" styleClass="page-subtitle"/>
                            <HBox spacing="10">
                                <Button text="Utwórz kopię zapasową" onAction="#createBackup"/>
                            </HBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </Tab>

            <Tab text="Dane podmiotu">
                <ScrollPane fitToWidth="true" fitToHeight="true">
                    <content>
                        <VBox spacing="16" styleClass="content-card">
                            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                            <Label text="Dane szkółki / wystawcy" styleClass="stat-title"/>
                            <Label text="Te dane będą wykorzystywane w dokumentach, kopii zapasowej systemu i na pulpicie stanu systemu." wrapText="true" styleClass="page-subtitle"/>

                            <GridPane hgap="12" vgap="12">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="180"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                </columnConstraints>

                                <Label text="Nazwa" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                <TextField fx:id="issuerNameField" promptText="Nazwa szkółki / wystawcy" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                <Label text="Kraj" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="issuerCountryField"
                                          editable="true"
                                          promptText="Wpisz lub wybierz kraj"
                                          maxWidth="1.7976931348623157E308"
                                          GridPane.rowIndex="1"
                                          GridPane.columnIndex="1"/>

                                <Label text="Kod kraju" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="issuerCountryCodeField"
                                          editable="true"
                                          promptText="Wpisz lub wybierz kod kraju"
                                          maxWidth="1.7976931348623157E308"
                                          GridPane.rowIndex="2"
                                          GridPane.columnIndex="1"/>

                                <Label text="Kod pocztowy" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                <TextField fx:id="issuerPostalCodeField" promptText="np. 00-000" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                                <Label text="Miasto" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                <TextField fx:id="issuerCityField" promptText="Miasto" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                                <Label text="Ulica i nr" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                                <HBox spacing="10" alignment="CENTER_LEFT" GridPane.rowIndex="5" GridPane.columnIndex="1">
                                    <TextField fx:id="issuerStreetField" promptText="Ulica i numer" HBox.hgrow="ALWAYS"/>
                                    <CheckBox fx:id="issuerNoStreetCheckBox" text="Brak ulicy"/>
                                </HBox>

                                <Label text="Nr fitosanitarny" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                                <TextField fx:id="issuerPhytosanitaryNumberField" promptText="Numer fitosanitarny" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
                            </GridPane>

                            <VBox spacing="8" styleClass="stat-card">
                                <Label text="Stan profilu" styleClass="stat-title"/>
                                <Label fx:id="issuerStatusLabel" wrapText="true" styleClass="page-subtitle"/>
                                <Label fx:id="issuerSummaryLabel" wrapText="true" styleClass="page-subtitle"/>
                            </VBox>

                            <HBox spacing="10" alignment="CENTER_RIGHT">
                                <Button text="Wyczyść formularz" onAction="#clearIssuerProfileForm" styleClass="button-secondary"/>
                                <Button text="Zapisz dane podmiotu" onAction="#saveIssuerProfile"/>
                            </HBox>

                        </VBox>
                    </content>
                </ScrollPane>
            </Tab>
        </tabs>
    </TabPane>
</VBox>